// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdRecord {
  id              String   @id @default(cuid())

  // Identity
  brand           String
  foreplayUrl     String
  landingPageUrl  String

  // Analysis Fields (8 rich text fields)
  hook            String   @db.Text
  concept         String   @db.Text
  scriptBreakdown String   @db.Text
  visual          String   @db.Text
  psychology      String   @db.Text
  cta             String   @db.Text
  keyTakeaways    String   @db.Text
  productionFormula String @db.Text

  // Scoring
  adScore         Float    @default(0)
  longevityDays   Int      @default(0)
  hookType        String   @default("")
  primaryAngle    String   @default("")
  frameworkName   String   @default("")
  creativePattern String   @default("")

  // Crawl Metadata
  adLibraryId     String   @unique
  adLibraryUrl    String
  region          String   // "US" | "UK" | "AU"
  keyword         String
  status          String   @default("active") // "active" | "inactive" | "partial"
  crawledAt       DateTime @default(now())

  // Video & Media
  videoUrl        String?
  thumbnailUrl    String?
  durationSeconds Float?
  videoFormat     String?  // "9:16" | "1:1" | "16:9" | "4:5" | "unknown"

  // New fields
  adStartDate      String?  // Raw ISO date from ad_delivery_start_time
  adIterationCount Int?     // "X ads use this creative and text"
  isActive         Boolean  @default(true)

  // Monetization
  impressionsLower String?
  impressionsUpper String?
  spendLower       String?
  spendUpper       String?
  spendCurrency    String?

  pageId          String?
  pageName        String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  savedAds        SavedAd[]

  @@index([region])
  @@index([brand])
  @@index([adScore])
  @@index([status])
  @@index([pageName])
}

model CompetitorScore {
  id              String   @id @default(cuid())

  brand           String
  region          String
  adCountScore    Int
  longevityScore  Int
  omnichannelScore Int
  marketFitScore  Int
  compositeScore  Float
  activeAdCount   Int
  oldestAdDays    Int
  platforms       String[] // Array of platform names
  marketsServed   String[] // Array of market codes
  pageId          String?

  crawlJobId      String?
  crawlJob        CrawlJob? @relation(fields: [crawlJobId], references: [id])

  createdAt       DateTime @default(now())

  @@unique([brand, region])
  @@index([compositeScore])
}

model CrawlJob {
  id              String   @id @default(cuid())

  markets         String[] // ["US", "UK", "AU"]
  keyword         String
  yourBrand       String
  mode            String   // "demo" | "full"

  status          String   @default("queued")
  // "queued" | "scoring" | "crawling" | "analysing" | "building_excel" | "complete" | "failed"

  progress        Int      @default(0) // 0-100
  adsProcessed    Int      @default(0)
  adsTotal        Int      @default(0)
  currentBrand    String?
  currentRegion   String?
  excelPath       String?
  sheetUrl        String?
  error           String?

  startedAt       DateTime @default(now())
  completedAt     DateTime?

  competitors     CompetitorScore[]

  @@index([status])
}

model Board {
  id          String    @id @default(cuid())
  name        String
  description String?
  color       String    @default("#7F77DD")
  icon        String    @default("bookmark")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  savedAds    SavedAd[]
}

model SavedAd {
  id       String   @id @default(cuid())
  boardId  String
  board    Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  adId     String
  ad       AdRecord @relation(fields: [adId], references: [id], onDelete: Cascade)
  notes    String?  @db.Text
  savedAt  DateTime @default(now())

  @@unique([boardId, adId])
  @@index([boardId])
  @@index([adId])
}

model Brief {
  id            String   @id @default(cuid())
  targetProduct String
  targetMarket  String
  basedOnAdIds  String[]
  briefJson     Json
  userContext    String?  @db.Text
  notes         String?  @db.Text
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([targetProduct])
  @@index([isArchived])
}

model ProductProfile {
  id              String   @id @default(cuid())
  name            String   @unique
  landingPageUrls String[]
  bigIdea         String?  @db.Text
  productInfo     String?  @db.Text
  targetAudience  String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Brand {
  id         String      @id @default(cuid())
  name       String      @unique
  logoUrl    String?
  products   Product[]
  characters Character[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Product {
  id              String   @id @default(cuid())
  brandId         String
  brand           Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name            String
  landingPageUrls String[]
  images          String[] // base64 or hosted URLs
  bigIdea         String?  @db.Text
  productInfo     String?  @db.Text
  targetAudience  String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([brandId, name])
  @@index([brandId])
}

model Character {
  id          String   @id @default(cuid())
  brandId     String?
  brand       Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  name        String
  description String?  @db.Text
  imageUrl    String?  @db.Text
  voiceId     String?
  voiceSource String?  // "gemini" | "elevenlabs"
  voiceName   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([brandId])
}

model StudioProject {
  id        String   @id @default(cuid())
  name      String
  step      Int      @default(1)
  stateJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

model StudioFolder {
  id        String         @id @default(cuid())
  name      String
  parentId  String?
  parent    StudioFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  StudioFolder[] @relation("FolderTree")
  assets    StudioAsset[]
  createdAt DateTime       @default(now())

  @@index([parentId])
}

model StudioAsset {
  id        String        @id @default(cuid())
  type      String        // "image" | "video"
  url       String
  name      String
  folderId  String?
  folder    StudioFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  metadata  Json?
  createdAt DateTime      @default(now())

  @@index([folderId])
  @@index([type])
}

model PromptBlueprint {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  content     String   @db.Text
  type        String   // "analyze" | "script" | "storyboard" | "enhance"
  variant     String   @default("default")
  version     Int      @default(1)
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([type, isActive])
}
